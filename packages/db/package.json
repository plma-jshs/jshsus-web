{
  "name": "@jshsus/db",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prebuild": "pnpm clean",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:backup": "node scripts/backup-database.cjs",
    "db:create-local-test-user": "node scripts/create-local-test-user.cjs",
    "db:assert-local": "node -e \"require('./scripts/local-seed-safety.cjs').assertLocalSeedAllowed(); console.log('Local database target verified.')\"",
    "db:bootstrap-local": "pnpm db:assert-local && pnpm db:migrate && pnpm db:create-local-test-user"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "mysql2": "3.22.6"
  },
  "devDependencies": {
    "drizzle-kit": "0.31.10",
    "typescript": "5.9.3"
  }
}
