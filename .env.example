NODE_ENV=development
TZ=Asia/Seoul
API_PORT=4000
WEB_PORT=5173
ADMIN_PORT=5174
API_ORIGIN=http://localhost:4000
API_BASE_URL=http://localhost:4000/api
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://jshsus.kr,https://admin.jshsus.kr

MYSQL_PORT=3306
MYSQL_VOLUME_NAME=jshs_web_mysql-data
REDIS_PORT=6379
MYSQL_USER=jshs_web
MYSQL_PASSWORD=local_mysql_password
MYSQL_ROOT_PASSWORD=local_mysql_root_password
DATABASE_URL=mysql://jshs_web:local_mysql_password@localhost:3306/jshsus
MIGRATION_DATABASE_URL=mysql://jshs_web:local_mysql_password@localhost:3306/jshsus
DATABASE_SSL_MODE=disabled
# docker-compose.yml은 기본적으로 내부 MySQL을 사용합니다. 별도 DB가 필요할 때만 설정하세요.
COMPOSE_DATABASE_URL=
DATABASE_SSL_CA_PATH=
BACKUP_RETENTION_COUNT=14
LEGACY_PLMA_DATABASE_URL=

# 로컬 테스트 계정/데모 데이터 명령은 실행할 때만 true로 주입합니다.
ALLOW_LOCAL_SEED=false
TEST_USER_USERNAME=9999
TEST_USER_PASSWORD=Hello00!
TEST_USER_STUDENT_NO=9999

# 공개 스테이징에서만 사용하는 멱등 데모 시드. 운영에서는 모두 false/production으로 둡니다.
SEED_DEMO_DATA=false
DEPLOYMENT_TIER=development
ALLOW_STAGING_DEMO_SEED=false
DEMO_SEED_DATABASE_NAME=

REDIS_PASSWORD=local_redis_password
REDIS_URL=redis://:local_redis_password@localhost:6379/0
SESSION_COOKIE_DOMAIN=localhost
SESSION_COOKIE_HOST_ONLY=false
SESSION_COOKIE_SECURE=false
CSRF_SECRET=change-this-csrf-secret
CSRF_COOKIE_NAME=jshsus.csrf
AUTH_MODE=cognito
# Cognito app-client secrets belong in the server environment, never in a Vite
# variable or browser bundle. Local/test builds can leave these blank, but real
# login and production deployments require valid values.
COGNITO_REGION=ap-northeast-2
COGNITO_USER_POOL_ID=
# Optional single app-client aliases. When set, they are reused for both web
# and admin surfaces unless the surface-specific values below are provided.
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_WEB_CLIENT_ID=
COGNITO_WEB_CLIENT_SECRET=
COGNITO_ADMIN_CLIENT_ID=
COGNITO_ADMIN_CLIENT_SECRET=
COGNITO_FLOW_TTL_SECONDS=300
COGNITO_REQUEST_TIMEOUT_MS=5000
LEGACY_SYSTEM_ADMIN_STUIDS=9988
LEGACY_STUDENT_AFFAIRS_HEAD_STUIDS=
SMOKE_ADMIN_STUDENT_NO=9988

IAM_COOKIE_NAME=iam_token
IAM_TOKEN_TTL_SECONDS=86400
IAM_REMEMBER_TOKEN_TTL_SECONDS=2592000
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_PUBLIC_BASE_URL=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false

FILE_UPLOAD_MAX_MB=10
FILE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,application/pdf
FILE_LOCAL_DIR=/tmp/jshsus-uploads
FILE_CLEANUP_BATCH_SIZE=20
FILE_CLEANUP_INTERVAL_MS=60000
FILE_CLEANUP_LOCK_TIMEOUT_MS=300000
FILE_CLEANUP_RETRY_BASE_MS=30000
FILE_CLEANUP_RETRY_MAX_MS=3600000

RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX=60

NEIS_API_KEY=
# Required in production: validates JBS and wake-song videos through YouTube Data API v3.
YOUTUBE_API_KEY=
NEIS_ATPT_OFCDC_SC_CODE=Q10
NEIS_SD_SCHUL_CODE=7140163
NEIS_REQUEST_TIMEOUT_MS=3500
NEIS_CACHE_TTL_SECONDS=3600
